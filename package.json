{
  "name": "favorites-to-wiki",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/app/main.ts",
    "start": "node dist/app/main.js",
    "worker": "tsx src/app/worker.ts",
    "prebuild": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "attachments:retry": "tsx src/app/retry-attachments.ts",
    "preprocess:run": "tsx src/app/preprocess.ts",
    "media:process": "tsx src/app/media-process.ts",
    "embeddings:run": "tsx src/app/embeddings.ts",
    "classify:run": "tsx src/app/classify.ts",
    "images:analyze": "tsx src/app/image-analysis.ts",
    "import:telegram": "tsx src/import/telegram-export.ts"
  },
  "dependencies": {
    "@grammyjs/files": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.44.0",
    "node-fetch": "^3.3.2",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.19.1",
    "vitest": "^2.1.8"
  }
}
